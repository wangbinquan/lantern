{
  "name": "lantern",
  "version": "0.0.0",
  "description": "MCP server that connects to an SSH-only, network-isolated environment and executes commands (multi-hop/su)",
  "private": true,
  "type": "module",
  "bin": {
    "lantern": "src/cli/lantern.ts",
    "lantern-mcp": "src/mcp/server.ts"
  },
  "scripts": {
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint": "oxlint src tests",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "test:coverage": "bun test --coverage"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ssh2": "^1.16.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/ssh2": "^1.15.5",
    "oxlint": "^1.0.0",
    "prettier": "3.4.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
